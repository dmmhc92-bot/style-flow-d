        "ascApiKeyPath": "./keys/AuthKey_7H48ZU4AD2.p8",
        "ascApiKeyIssuerId": "e05d02ae-8a38-478e-a195-ffe1d868ef44",
        "ascApiKeyId": "7H48ZU4AD2"
      }
    },
    "production": {
