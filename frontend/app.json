{
  "expo": {
    "name": "StyleFlow",
    "slug": "styleflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "styleflow",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "owner": "styleflow",
    "description": "Premium hairstylist business app for client management, formula vault, and portfolio showcase",
    "primaryColor": "#8BA889",
    "extra": {
      "eas": {
        "projectId": "b1fe50c3-30ac-4f2f-b705-38933734178b"
      }
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/b1fe50c3-30ac-4f2f-b705-38933734178b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.styleflow.app",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:homestyleflowapp.com",
        "webcredentials:homestyleflowapp.com"
      ],
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload stunning client photos to your portfolio",
        "NSCameraUsageDescription": "Capture before & after transformations",
        "NSPhotoLibraryAddUsageDescription": "Save your work to device gallery",
        "NSFaceIDUsageDescription": "Secure login with Face ID",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["styleflow"]
          }
        ]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      },
      "appStoreUrl": "https://apps.apple.com/app/styleflow/id6761026979"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2D2D2D"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.styleflow.app",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "homestyleflowapp.com",
              "pathPrefix": "/reset-password"
            },
            {
              "scheme": "https",
              "host": "homestyleflowapp.com",
              "pathPrefix": "/hub"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2D2D2D"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload stunning client photos to your portfolio",
          "cameraPermission": "Capture before & after transformations"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Capture before & after transformations"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "locales": {
      "en": "./locales/en.json"
    }
  }
}
